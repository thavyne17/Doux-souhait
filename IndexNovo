<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Loja de Doces - Ofertas incríveis em chocolates, confeitaria e muito mais. Frete grátis em compras acima de R$100!">
    <meta name="keywords" content="doces, chocolates, confeitaria, promoções, black friday, loja online">
    <meta name="author" content=" doux souhait">
    <meta property="og:title" content=" doux souhait - Doces Incríveis">
    <meta property="og:description" content="Descubra as melhores ofertas em doces, chocolates e confeitaria!">
    <meta property="og:image" content="banner.jpg">
    <meta property="og:url" content="https://www.sualoja.com">
    <meta name="theme-color" content="#ff6f61">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap" rel="stylesheet">
    <link rel="icon" href="favicon.ico" type="image/x-icon">
    <title>Loja de Doces - Promoções Imperdíveis</title>
    <style>
        :root {
            --primary-color: #fdeaf2;
            --secondary-color: #ffc9d6;
            --background-color: #fdeaf2;
            --text-color: #ffffff;
            --white: #745050;
            --highlight-color: #ecc5c1;
            --success-color: #388e3c;
        }

        /* Reset */
        *, *::before, *::after {
            box-sizing: border-box;
        }

        /* Corpo */
        body {
            font-family: 'Poppins', sans-serif;
            margin: 0;
            padding: 0;
            background-color: var(--background-color);
            color: var(--text-color);
        }

        /* Botão Portfólio */
        .portfolio-btn {
            position: fixed;
            top: 18px;
            left: 18px;
            z-index: 9999;
            display: flex;
            align-items: center;
            gap: 8px;
            background: linear-gradient(135deg, #745050, #a06070);
            color: #fdeaf2;
            text-decoration: none;
            font-family: 'Poppins', sans-serif;
            font-size: 0.82rem;
            font-weight: 600;
            letter-spacing: 0.5px;
            padding: 9px 18px 9px 14px;
            border-radius: 30px;
            box-shadow: 0 4px 14px rgba(116, 80, 80, 0.45), 0 1px 3px rgba(0,0,0,0.15);
            transition: all 0.25s ease;
            white-space: nowrap;
            border: 1.5px solid rgba(253, 234, 242, 0.25);
        }

        .portfolio-btn:hover {
            background: linear-gradient(135deg, #a06070, #ecc5c1);
            color: #5a3030;
            transform: translateX(-3px) scale(1.03);
            box-shadow: 0 6px 18px rgba(116, 80, 80, 0.5);
            border-color: rgba(116, 80, 80, 0.2);
        }

        .portfolio-btn .arrow {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 22px;
            height: 22px;
            background: rgba(253, 234, 242, 0.2);
            border-radius: 50%;
            font-size: 0.85rem;
            line-height: 1;
            transition: background 0.25s ease, transform 0.25s ease;
            flex-shrink: 0;
        }

        .portfolio-btn:hover .arrow {
            background: rgba(90, 48, 48, 0.12);
            transform: translateX(-2px);
        }

        /* Cabeçalho */
        header {
            background: var(--primary-color);
            color: var(--white);
            padding: 1.5rem 1rem;
            text-align: center;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        header h1 {
            font-size: clamp(1.5rem, 5vw, 2.5rem);
            margin: 0;
        }

        /* Barra de Navegação */
        nav {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 0.5rem;
            background-color: var(--secondary-color);
            padding: 0.8rem 1rem;
        }

        nav a {
            color: var(--white);
            text-decoration: none;
            font-weight: bold;
            font-size: clamp(0.75rem, 2.5vw, 0.95rem);
            padding: 0.4rem 0.8rem;
            border-radius: 5px;
            transition: background-color 0.3s;
            white-space: nowrap;
        }

        nav a:hover {
            background-color: var(--primary-color);
        }

        /* Banner */
        .banner {
            display: flex;
            justify-content: center;
            align-items: center;
            background-image: url('banner.jpg');
            background-size: cover;
            background-position: center;
            min-height: 200px;
            height: clamp(180px, 30vw, 300px);
            color: var(--white);
            text-align: center;
            padding: 20px;
            text-shadow: 2px 2px 8px #8d606b;
        }

        .banner h1 {
            font-size: clamp(1.1rem, 4vw, 2.5em);
            margin: 0;
        }

        /* Produtos */
        .offers-section {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            padding: 20px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .offer {
            background: var(--white);
            border-radius: 8px;
            box-shadow: 0 4px 8px #7409091a;
            text-align: center;
            padding: 20px;
            transition: transform 0.3s;
        }

        .offer:hover {
            transform: translateY(-5px);
        }

        .offer img {
            max-width: 100%;
            width: 100%;
            height: auto;
            border-radius: 8px;
            margin-bottom: 15px;
            display: block;
        }

        .offer h3 {
            color: var(--primary-color);
            margin-bottom: 10px;
            font-size: clamp(1rem, 2.5vw, 1.2em);
        }

        .offer p {
            font-weight: bold;
            color: var(--success-color);
            margin-bottom: 10px;
        }

        .offer button {
            background: var(--primary-color);
            color: var(--white);
            border: none;
            padding: 10px 15px;
            border-radius: 5px;
            cursor: pointer;
            transition: transform 0.3s, background 0.3s;
            font-family: 'Poppins', sans-serif;
            font-size: 0.9rem;
        }

        .offer button:hover {
            background: var(--highlight-color);
            transform: scale(1.05);
        }

        /* Modal */
        #product-modal {
            display: none;
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 90%;
            max-width: 400px;
            background: white;
            box-shadow: 0 4px 8px rgba(0,0,0,0.3);
            padding: 20px;
            border-radius: 10px;
            z-index: 1000;
        }

        #product-modal h3 {
            margin-bottom: 10px;
            color: #d32f2f;
        }

        #modal-image {
            width: 100%;
            border-radius: 8px;
            margin-bottom: 15px;
            height: auto;
        }

        #modal-price {
            color: #388e3c;
            font-weight: bold;
            margin-bottom: 15px;
        }

        #add-to-cart {
            background: linear-gradient(45deg, #d32f2f, #ff6f61);
            color: white;
            padding: 10px 15px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-family: 'Poppins', sans-serif;
        }

        #close-modal {
            margin-top: 10px;
            background: #ccc;
            color: black;
            padding: 5px 10px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-family: 'Poppins', sans-serif;
        }

        /* Carrinho */
        .cart {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: var(--primary-color);
            color: var(--white);
            border-radius: 50%;
            width: 60px;
            height: 60px;
            display: flex;
            justify-content: center;
            align-items: center;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
            cursor: pointer;
            transition: transform 0.3s;
            font-size: 1.1rem;
        }

        .cart:hover {
            transform: scale(1.1);
        }

        footer {
            background: var(--primary-color);
            color: var(--white);
            text-align: center;
            padding: 1rem;
            font-size: clamp(0.75rem, 2vw, 0.95rem);
        }

        /* Título de Seção */
        .section-title {
            text-align: center;
            color: #745050;
            font-size: clamp(1.1rem, 3vw, 1.5rem);
            margin: 30px 0 0;
            padding: 0 20px;
            font-weight: 600;
            letter-spacing: 1px;
        }

        .section-title::after {
            content: '';
            display: block;
            width: 50px;
            height: 3px;
            background: linear-gradient(90deg, #ecc5c1, #ffc9d6);
            border-radius: 2px;
            margin: 8px auto 0;
        }

        /* Preço riscado */
        .price-old {
            font-size: 0.8em;
            color: #aaa;
            text-decoration: line-through;
            font-weight: 400;
            margin-left: 4px;
        }

        /* Responsividade extra pequena */
        @media (max-width: 400px) {
            .offers-section {
                grid-template-columns: 1fr;
                padding: 12px;
            }

            nav a {
                padding: 0.3rem 0.5rem;
                font-size: 0.72rem;
            }

            .portfolio-btn {
                font-size: 0.78rem;
                padding: 6px 10px;
            }
        }
    </style>
</head>
<body>

